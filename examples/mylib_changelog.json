{
    "library": "mylib",
    "versions": [
        {
            "version": "1.1.0",
            "release_date": "2024-01-15",
            "notes": "Minor improvements and deprecations",
            "rules": [
                {
                    "change_type": "deprecate_function",
                    "version_introduced": "1.1.0",
                    "description": "fetch_data() is deprecated, use get_data() instead",
                    "old_name": "fetch_data",
                    "replacement": "get_data"
                }
            ]
        },
        {
            "version": "2.0.0",
            "release_date": "2024-03-01",
            "notes": "Major breaking release",
            "rules": [
                {
                    "change_type": "rename_function",
                    "version_introduced": "2.0.0",
                    "description": "Renamed connect() to create_connection()",
                    "old_name": "connect",
                    "new_name": "create_connection"
                },
                {
                    "change_type": "rename_class",
                    "version_introduced": "2.0.0",
                    "description": "Client class renamed to APIClient",
                    "old_name": "Client",
                    "new_name": "APIClient"
                },
                {
                    "change_type": "rename_import",
                    "version_introduced": "2.0.0",
                    "description": "Client moved to new module",
                    "old_name": "Client",
                    "new_name": "APIClient",
                    "old_module": "mylib",
                    "new_module": "mylib.client"
                },
                {
                    "change_type": "add_argument",
                    "version_introduced": "2.0.0",
                    "description": "Added timeout parameter to create_connection()",
                    "function_name": "create_connection",
                    "argument_name": "timeout",
                    "default_value": "30"
                },
                {
                    "change_type": "rename_attribute",
                    "version_introduced": "2.0.0",
                    "description": "Renamed .url attribute to .base_url",
                    "old_name": "url",
                    "new_name": "base_url"
                }
            ]
        },
        {
            "version": "2.1.0",
            "release_date": "2024-04-10",
            "notes": "Additional improvements",
            "rules": [
                {
                    "change_type": "remove_argument",
                    "version_introduced": "2.1.0",
                    "description": "Removed deprecated verbose argument from send_request()",
                    "function_name": "send_request",
                    "argument_name": "verbose"
                },
                {
                    "change_type": "move_to_module",
                    "version_introduced": "2.1.0",
                    "description": "Moved Formatter class to mylib.utils",
                    "old_name": "Formatter",
                    "source_module": "mylib.helpers",
                    "target_module": "mylib.utils"
                },
                {
                    "change_type": "replace_with_property",
                    "version_introduced": "2.1.0",
                    "description": "get_name() replaced by .name property",
                    "old_name": "get_name",
                    "new_name": "name"
                }
            ]
        },
        {
            "version": "3.0.0",
            "release_date": "2024-06-01",
            "notes": "Full rewrite",
            "rules": [
                {
                    "change_type": "rename_function",
                    "version_introduced": "3.0.0",
                    "description": "send_request() renamed to request()",
                    "old_name": "send_request",
                    "new_name": "request"
                },
                {
                    "change_type": "add_decorator",
                    "version_introduced": "3.0.0",
                    "description": "All handler functions must be decorated with @handler",
                    "function_name": "on_response",
                    "decorator_name": "handler"
                },
                {
                    "change_type": "change_argument_default",
                    "version_introduced": "3.0.0",
                    "description": "Default timeout changed from 30 to 60",
                    "function_name": "create_connection",
                    "argument_name": "timeout",
                    "default_value": "60"
                }
            ]
        }
    ]
}